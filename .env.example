POSTGRES_DB=your_postgres_db
POSTGRES_USER=your_postgres_user
# Required: set a strong unique password before running docker compose.
POSTGRES_PASSWORD=replace_with_strong_password
# Leave these unset to use the default published latest tags from Docker Hub.
# To pin a release, set both values to matching versioned images such as
# `backend-v1.0.3` and `frontend-v1.0.3`.
# BACKEND_IMAGE=gptvibe/fundamentalterminal:backend-v1.0.3
# FRONTEND_IMAGE=gptvibe/fundamentalterminal:frontend-v1.0.3
# Required: keep in sync with POSTGRES_DB/POSTGRES_USER/POSTGRES_PASSWORD.
DATABASE_URL=postgresql+psycopg://your_postgres_user:replace_with_strong_password@postgres:5432/your_postgres_db
REDIS_URL=redis://redis:6379/0
BACKEND_API_BASE_URL=http://backend:8000
FRESHNESS_WINDOW_HOURS=24
SEC_USER_AGENT=FundamentalTerminal/1.0 (contact@example.com)
# SEC expects a descriptive user agent with a monitored email or URL.
SEC_TIMEOUT_SECONDS=30
MARKET_USER_AGENT=FundamentalTerminal/1.0 (contact@example.com)
# Optional override for Yahoo Finance and other market-data HTTP clients.
MARKET_TIMEOUT_SECONDS=30
SEC_MIN_REQUEST_INTERVAL_SECONDS=0.2
SEC_TICKER_CACHE_TTL_SECONDS=86400
SEC_MAX_RETRIES=3
SEC_RETRY_BACKOFF_SECONDS=0.5
MARKET_MAX_RETRIES=3
MARKET_RETRY_BACKOFF_SECONDS=0.5
STRICT_OFFICIAL_MODE=false
MARKET_CONTEXT_CACHE_TTL_HOURS=6
FRED_API_KEY=
# Get a FRED API key: https://fredaccount.stlouisfed.org/apikeys
CENSUS_API_BASE_URL=https://api.census.gov/data/timeseries/eits
CENSUS_API_KEY=
BLS_API_BASE_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
BLS_API_KEY=
# Get a BLS API key: https://data.bls.gov/registrationEngine/
EIA_API_BASE_URL=https://api.eia.gov/v2
EIA_API_KEY=
# Get an EIA API key: https://www.eia.gov/opendata/register.php
BEA_API_BASE_URL=https://apps.bea.gov/api/data
BEA_API_KEY=
# Get a BEA API key: https://apps.bea.gov/api/signup/
OBSERVABILITY_ENABLED=true
PERFORMANCE_AUDIT_ENABLED=false
SECURITY_HEADERS_ENABLED=true
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=180
API_RATE_LIMIT_WINDOW_SECONDS=60
# Dedicated Redis namespace for public API rate-limit counters. Set this to the
# legacy `ft:hot-cache:rate-limit` prefix only if you intentionally need that
# old layout during a migration.
RATE_LIMIT_NAMESPACE=ft:rate-limit
# Keep false unless you run behind a trusted reverse proxy that overwrites
# X-Forwarded-For and blocks client-supplied forwarding headers.
API_RATE_LIMIT_TRUST_PROXY=false
# Comma-separated public paths that should bypass public API rate limiting.
API_RATE_LIMIT_EXEMPT_PATHS=/health,/readyz,/docs,/redoc,/openapi.json
AUTH_MODE=off
# For AUTH_MODE=bearer, set AUTH_BEARER_TOKEN to a long random secret and keep it out of source control.
AUTH_BEARER_TOKEN=
# For AUTH_MODE=forwarded-user, your reverse proxy should inject this header for authenticated users.
AUTH_FORWARDED_USER_HEADER=X-Forwarded-User
# Protect internal operator routes by default; add more comma-separated prefixes if needed.
AUTH_REQUIRED_PATH_PREFIXES=/api/internal
AUTH_EXEMPT_PATHS=/health,/readyz
HEALTH_SEC_CHECK_ENABLED=true
HEALTH_SEC_CHECK_TIMEOUT_SECONDS=2.5
HEALTH_SEC_CHECK_CACHE_SECONDS=30
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_TTL_SECONDS=45
WORKER_IDENTIFIERS=AAPL MSFT NVDA AMZN
WORKER_INTERVAL_SECONDS=3600
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SECONDS=30
REFRESH_QUEUE_POLL_SECONDS=1
DATA_FETCHER_ENABLED=true
DATA_FETCHER_STARTUP_DELAY_SECONDS=0
DATA_FETCHER_ENQUEUE_ON_STARTUP=false
DATA_FETCHER_RUN_MACRO_WORKER=true
SP500_PREWARM_MODE=refresh
SP500_PREWARM_LIMIT=
DUPONT_MODE=auto

# For ~1 GB hosts, prefer the compose override profile instead of copying the
# larger-host defaults above into a local `.env`:
#   docker compose -f docker-compose.yml -f docker-compose.small-host.yml up -d
# The small-host profile pins backend/worker DB pools to 5/5, slows queue polls
# to 5s, delays worker startup by 120s, narrows scheduled refresh tickers to
# AAPL/MSFT, disables startup macro refresh, and caps S&P 500 prewarm to a small
# core slice when that profile is used.

# Optional demo-safe overrides for a 2 CPU / 2 GB deployment:
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT_SECONDS=30
# REFRESH_QUEUE_POLL_SECONDS=5
# DATA_FETCHER_STARTUP_DELAY_SECONDS=120
# SP500_PREWARM_MODE=core
# SP500_PREWARM_LIMIT=25
