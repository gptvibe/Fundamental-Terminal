POSTGRES_DB=fundamentals
POSTGRES_USER=fundamental
POSTGRES_PASSWORD=fundamental
BACKEND_IMAGE=gptvibe/fundamentalterminal:backend-latest
FRONTEND_IMAGE=gptvibe/fundamentalterminal:frontend-latest
DATABASE_URL=postgresql+psycopg://fundamental:fundamental@postgres:5432/fundamentals
REDIS_URL=redis://redis:6379/0
BACKEND_API_BASE_URL=http://backend:8000
FRESHNESS_WINDOW_HOURS=24
SEC_USER_AGENT=FundamentalTerminal/1.0 (contact@example.com)
SEC_TIMEOUT_SECONDS=30
SEC_MIN_REQUEST_INTERVAL_SECONDS=0.2
SEC_TICKER_CACHE_TTL_SECONDS=86400
SEC_MAX_RETRIES=3
SEC_RETRY_BACKOFF_SECONDS=0.5
MARKET_MAX_RETRIES=3
MARKET_RETRY_BACKOFF_SECONDS=0.5
STRICT_OFFICIAL_MODE=false
MARKET_CONTEXT_CACHE_TTL_HOURS=6
FRED_API_KEY=
# Get a FRED API key: https://fredaccount.stlouisfed.org/apikeys
CENSUS_API_BASE_URL=https://api.census.gov/data/timeseries/eits
CENSUS_API_KEY=
BLS_API_BASE_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
BLS_API_KEY=
# Get a BLS API key: https://data.bls.gov/registrationEngine/
EIA_API_BASE_URL=https://api.eia.gov/v2
EIA_API_KEY=
# Get an EIA API key: https://www.eia.gov/opendata/register.php
BEA_API_BASE_URL=https://apps.bea.gov/api/data
BEA_API_KEY=
# Get a BEA API key: https://apps.bea.gov/api/signup/
WORKER_IDENTIFIERS=AAPL MSFT NVDA AMZN
WORKER_INTERVAL_SECONDS=3600
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SECONDS=30
REFRESH_QUEUE_POLL_SECONDS=1
DATA_FETCHER_ENABLED=true
DATA_FETCHER_STARTUP_DELAY_SECONDS=0
DATA_FETCHER_ENQUEUE_ON_STARTUP=true
DATA_FETCHER_RUN_MACRO_WORKER=true
SP500_PREWARM_MODE=refresh
SP500_PREWARM_LIMIT=
DUPONT_MODE=auto

# Optional demo-safe overrides for a 2 CPU / 2 GB deployment:
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT_SECONDS=30
# REFRESH_QUEUE_POLL_SECONDS=5
# DATA_FETCHER_STARTUP_DELAY_SECONDS=120
# SP500_PREWARM_MODE=core
# SP500_PREWARM_LIMIT=25

